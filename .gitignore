.env
.env.*
!.env.example
.env.tmp
.venv
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
logs/
*.db
*.sqlite
.DS_Store

# The bundled Python lives in runtime/ and IS committed, so a git download runs
# directly (no separate staging step). Only the per-machine, first-run-generated
# bits are kept out of git:
runtime/Lib/
runtime/Scripts/
runtime/.deps_installed
runtime/python-embed.zip

# Packaging / build outputs
build/
dist/
.venv-build/
*.egg-info/

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# Personal sample dossier files (PII) — only the template is committed
sample_dossier/*
!sample_dossier/TEMPLATE_dossier.json
