# Copy this file to .env, or just configure everything from the app's
# Setup page — the app writes these values to .env for you. Never commit .env.

# --------------------------------------------------
# Main LLM provider — "openai", "anthropic", "groq", or "gemini"
# --------------------------------------------------
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
# Suggested models: gpt-4.1, gpt-4.1-mini, gpt-4o, gpt-4o-mini  (4o/4.1 = vision)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Anthropic (used when LLM_PROVIDER=anthropic; leave blank otherwise)
# Suggested models: claude-sonnet-4-6, claude-3-5-sonnet-latest, claude-3-5-haiku-latest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Groq (used when LLM_PROVIDER=groq; leave blank otherwise). Text-only here.
# Suggested models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (used when LLM_PROVIDER=gemini; leave blank otherwise)
# Suggested models: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash, gemini-2.0-flash-lite
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Vision model for reading job screenshots. VISION_PROVIDER may be "openai",
# "anthropic", "gemini", or "same_as_llm" (reuse LLM_PROVIDER when it supports
# images). Groq is NOT a valid vision provider — it is text-only in this app.
# VISION_MODEL must be a vision-capable model.
# Suggested vision models — OpenAI: gpt-4o, gpt-4.1; Anthropic: claude-sonnet-4-6,
# claude-3-5-sonnet-latest; Gemini: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash.
VISION_PROVIDER=openai
VISION_MODEL=gpt-4o

# --------------------------------------------------
# Safety / fallback controls — keep false for production-like behavior.
# When false, the main UI hides provider/model labels, task names, and raw
# API errors; only short, safe, actionable messages are shown.
# --------------------------------------------------
ALLOW_PROVIDER_FALLBACK=false
ALLOW_LOCAL_PLACEHOLDERS=false
SHOW_DEBUG_PANEL=false

# --------------------------------------------------
# Proposal context limits and logging. The full dossier is never sent; only
# a small relevance-filtered subset is.
# --------------------------------------------------
MAX_PROPOSAL_CONTEXT_CHARS=15000
MAX_PROPOSAL_EVIDENCE_POINTS=20
PROPOSAL_MAX_OUTPUT_TOKENS=700
LOG_RETENTION_DAYS=7
